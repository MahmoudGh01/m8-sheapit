    "depcheck": "^1.4.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "shadcn": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
